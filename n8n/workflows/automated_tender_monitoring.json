      "typeVersion": 4.2,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "resource": "mcp-tool",
        "operation": "call",
        "toolName": "extract_bid_blocks",
        "toolArguments": {
          "text": "={{ $json.body }}"
        },
        "mcpClient": {
          "__rl": true,
          "mode": "sse",
          "url": "http://127.0.0.1:8102/sse",
          "authentication": "none"
        }
      },
      "id": "analysis-extract",
      "name": "Extract Bid Blocks",
      "type": "n8n-nodes-base.mcpClient",
      "typeVersion": 1,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "tender-batch",
              "name": "Tender Batch",
              "value": "={{ $json }}",
              "type": "object"
            }
          ]
        }
      },
      "id": "prepare-batch",
      "name": "Prepare Batch",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "batchSize": 10,
        "options": {}
      },
