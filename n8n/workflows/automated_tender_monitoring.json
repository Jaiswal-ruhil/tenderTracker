      "typeVersion": 3,
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "resource": "mcp-tool",
        "operation": "call",
        "toolName": "classify_bid",
        "toolArguments": {
          "bid_obj": "={{ $json }}"
        },
        "mcpClient": {
          "__rl": true,
          "mode": "sse",
          "url": "http://127.0.0.1:8102/sse",
          "authentication": "none"
        }
      },
      "id": "analysis-classify",
      "name": "Classify Bid",
      "type": "n8n-nodes-base.mcpClient",
      "typeVersion": 1,
      "position": [
        1250,
        200
      ]
    },
    {
      "parameters": {
        "resource": "mcp-tool",
        "operation": "call",
        "toolName": "match_company_products",
        "toolArguments": {
          "bid_obj": "={{ $json }}"
        },
        "mcpClient": {
          "__rl": true,
          "mode": "sse",
          "url": "http://127.0.0.1:8102/sse",
          "authentication": "none"
        }
      },
      "id": "analysis-match",
      "name": "Match Products",
      "type": "n8n-nodes-base.mcpClient",
      "typeVersion": 1,
      "position": [
        1250,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "confidence-filter",
              "leftValue": "={{ $json.confidence }}",
              "rightValue": 0.7,
              "operator": {
                "type": "number",
                "operation": "larger"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "filter-confidence",
      "name": "Filter High Confidence",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1450,
        250
      ]
    },
    {
      "parameters": {
        "resource": "mcp-tool",
        "operation": "call",
        "toolName": "add_tender_record",
        "toolArguments": {
          "tender": "={{ $json }}"
        },
        "mcpClient": {
          "__rl": true,
          "mode": "sse",
          "url": "http://127.0.0.1:8101/sse",
          "authentication": "none"
        }
      },
      "id": "catalog-add",
      "name": "Add Tender Record",
      "type": "n8n-nodes-base.mcpClient",
      "typeVersion": 1,
      "position": [
        1650,
        250
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "company-match",
              "leftValue": "={{ $json.recommended }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-criteria",
      "name": "Check Company Criteria",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1850,
        250
      ]
    },
    {
      "parameters": {
        "channel": "tendertracker-alerts",
        "text": "=🚀 **New High-Value Tender Found!**\n\n**Bid No:** {{ $json.bid_no }}\n**Category:** {{ $json.category }}\n**Value:** {{ $json.est_value }}\n**Confidence:** {{ $json.confidence }}\n\n**Items:** {{ $json.items }}\n**Department:** {{ $json.dept }}\n**Deadline:** {{ $json.end_date }}\n\n📊 **AI Analysis:** {{ $json.summary }}",
        "otherOptions": {}
      },
      "id": "slack-alert",
      "name": "Send Slack Alert",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [
        2050,
        200
      ]
    },
    {
      "parameters": {
        "subject": "🚀 New High-Value Tender Alert - {{ $json.bid_no }}",
        "email": "procurement@company.com",
        "text": "=A new high-value tender matching your company criteria has been discovered:\n\n**Bid Number:** {{ $json.bid_no }}\n**Category:** {{ $json.category }}\n**Estimated Value:** {{ $json.est_value }}\n**AI Confidence Score:** {{ $json.confidence }}\n\n**Details:**\n- Items: {{ $json.items }}\n- Department: {{ $json.dept }}\n- Location: {{ $json.location }}\n- Deadline: {{ $json.end_date }}\n\n**AI Summary:** {{ $json.summary }}\n\nPlease review this opportunity in TenderTracker.",
        "options": {}
      },
      "id": "email-alert",
      "name": "Send Email Alert",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        2050,
        300
      ]
    },
